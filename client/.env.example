# Variables de entorno del cliente Vite (client/)
# Copia este archivo a .env.local (ignorado por git) y ajusta los valores.
# Vite solo expone variables que empiezan con VITE_ al codigo del navegador.

# URL base del backend Spring Boot (BackEnfriadores). Sin slash al final.
# Usado por client/src/api/httpClient.js para todas las llamadas REST.
VITE_API_URL=http://localhost:8080

# URL del bridge Node (Socket.IO). Default: http://localhost:3000.
VITE_SOCKET_URL=http://localhost:3000

# Si =true usa datos mock en useSocket en lugar de conectarse al bridge.
# Util para desarrollar la UI sin levantar EMQX ni los simuladores.
VITE_USE_MOCK=false

# Si =true usa mocks en los clientes REST (historial, intervenciones,
# alarma-activa) en lugar de pegarle al backend.
VITE_USE_MOCK_API=false

# Si =true bypassa el login y monta una sesion mock. EXCLUSIVO PARA
# DESARROLLO LOCAL — nunca lo dejes activado en una build de produccion.
VITE_DISABLE_AUTH=false
