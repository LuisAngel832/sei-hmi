# Variables de entorno del bridge Node (server/index.js)
# Copia este archivo a .env en la raiz del repo y ajusta los valores.
# server/config/index.js carga ../.env relativo al directorio server/.

# Hostname o IP del broker EMQX. Acepta hostname pelado, 'http://host[:puerto]'
# o 'mqtt://host'. El puerto se extrae aparte (MQTT_BROKER_PORT).
MQTT_BROKER_HOST=localhost

# Puerto MQTT del broker (1883 plano, 8883 TLS). Default: 1883.
MQTT_BROKER_PORT=1883

# Edad maxima (segundos) tolerada para mensajes retained. Los retained
# mas viejos se descartan para evitar mostrar datos rancios al hidratar
# la UI tras un reinicio del broker. Default: 120.
MQTT_MAX_RETAINED_AGE_SEC=120

# Puerto HTTP/Socket.IO del bridge. El cliente Vite apunta aqui por
# VITE_SOCKET_URL. Default: 3000.
PORT=3000
